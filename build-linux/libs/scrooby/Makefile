	cd /home/austinm/development/shar-linux/build-linux && $(MAKE) $(MAKESILENT) -f libs/scrooby/CMakeFiles/scrooby.dir/build.make libs/scrooby/CMakeFiles/scrooby.dir/src/xml/XMLParser.cpp.s
.PHONY : src/xml/XMLParser.cpp.s

